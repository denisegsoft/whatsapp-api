PORT=3001

# Clave para que Laravel pueda llamar a este servidor
API_KEY=cambia_esta_clave_por_una_segura

# URL del webhook en Laravel (en produccion usar localhost)
LARAVEL_WEBHOOK_URL=http://localhost/api/whatsapp/webhook

# Secret compartido: Laravel lo manda, Node lo verifica
WEBHOOK_SECRET=cambia_este_secret_por_uno_seguro
